# =============================================================================
# cBocior_as — Environment Variables Template
# Copy this file to .env and fill in your values.
# The .env file is git-ignored; never commit real secrets.
# =============================================================================

# ── cTrader Open API ──────────────────────────────────────────────────────────
CTRADER_CLIENT_ID=your_client_id_here
CTRADER_CLIENT_SECRET=your_client_secret_here
CTRADER_ACCESS_TOKEN=your_access_token_here
CTRADER_REFRESH_TOKEN=your_refresh_token_here
# Account 1 — initial capital 10 000 USD
CTRADER_ACCOUNT_ID=12345678
# Account 2 — initial capital 50 USD (leave blank to reuse Account 1 ID)
CTRADER_ACCOUNT_ID_ACC2=87654321
# LIVE or DEMO
CTRADER_ENVIRONMENT=DEMO

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-pro

# ── Groq ─────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama3-70b-8192

# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── LangSmith ─────────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=cBocior_as
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Trading Parameters ────────────────────────────────────────────────────────
TRADING_SYMBOL=EURUSD
TRADING_VOLUME=1          # centilots (lots × 100): 1=micro-lot, 10=mini-lot, 100=1 lot
TRADING_MAX_SPREAD_PIPS=2.0
TRADING_STOP_LOSS_PIPS=30
TRADING_TAKE_PROFIT_PIPS=60

# ── Risk Management ───────────────────────────────────────────────────────────
RISK_MAX_DRAWDOWN_PCT=5.0
RISK_MAX_POSITION_SIZE=10000
RISK_DAILY_LOSS_LIMIT_USD=500.0

# ── Model / Training ─────────────────────────────────────────────────────────
MODEL_EXPORT_DIR=./exports
DATA_DIR=./data
TRAIN_1M_TRADES=2000
TRAIN_1M_EPOCHS=200
TRAIN_5M_TRADES=1000
TRAIN_5M_EPOCHS=200
TRAIN_1H_TRADES=250
TRAIN_1H_EPOCHS=200

# ── Bot Behaviour ─────────────────────────────────────────────────────────────
BOT_LOOP_INTERVAL_SECONDS=10
BOT_ANALYSIS_COOLDOWN_SECONDS=60
BOT_MAX_CONCURRENT_AGENTS=4
LOG_LEVEL=INFO

# ── Account Capitals ──────────────────────────────────────────────────────────
INITIAL_CAPITAL_ACC1=10000
INITIAL_CAPITAL_ACC2=50

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_SECONDS=3600
REDIS_ENABLED=true
